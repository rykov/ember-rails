{
  "name": "ember-cli-rails",
  "version": "2.0.1-rc.4",
  "license": "MIT",
  "description": "Package Ember app for Rails Asset Pipeline",
  "homepage": "https://github.com/rykov/ember-cli-rails#readme",
  "author": "Michael Rykov",
  "main": "lib/ember-addon.js",
  "files": [
    "lib/",
    "templates/"
  ],
  "ember-addon": {
    "main": "lib/ember-addon.js",
    "demoURL": "https://badge.fury.io",
    "after": ["broccoli-asset-rev"]
  },
  "scripts": {
    "test": "node --test",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "ember-addon",
    "ember-cli",
    "rails"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rykov/ember-cli-rails.git"
  },
  "bugs": {
    "url": "https://github.com/rykov/ember-cli-rails/issues"
  },
  "engines": {
    "node": ">= 18"
  },
  "dependencies": {
    "broccoli-kitchen-sink-helpers": "^0.3.1",
    "broccoli-merge-trees": "^3.0.2",
    "broccoli-plugin": "^1.3.0",
    "ember-cli-babel": "^7.0.0",
    "fs-extra": "^11.3.4",
    "handlebars": "^4.7.7",
    "normalize-path": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "broccoli-asset-rev": "^3.0.0",
    "eslint": "^10.2.0"
  },
  "peerDependencies": {
    "@embroider/compat": ">=3.0.0",
    "@embroider/webpack": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@embroider/compat": { "optional": true },
    "@embroider/webpack": { "optional": true }
  }
}
